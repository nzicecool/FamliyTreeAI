rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "myozscoop@gmail.com";
    }

    // ===============================================================
    // Collection: invites
    // ===============================================================
    match /invites/{email} {
      // Only superadmin can create/update/delete invites
      allow write: if isSuperAdmin();
      // Anyone can check if an invite exists (needed for login check)
      // but we should ideally restrict this to the owner of the email if possible.
      // For the OTP flow, the server (Admin SDK) handles the check, 
      // so we can keep this restricted.
      allow read: if isSuperAdmin();
    }

    // ===============================================================
    // Collection: users
    // ===============================================================
    match /users/{userId} {
      // Users can only read and write their own data
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /people/{personId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }

      match /meta/{metaId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // ===============================================================
    // Collection: otps
    // ===============================================================
    match /otps/{email} {
      // Server handles OTP creation and verification via Admin SDK.
      // No client-side access needed.
      allow read, write: if false;
    }
    
    // ===============================================================
    // Collection: test
    // ===============================================================
    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
