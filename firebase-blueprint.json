{
  "entities": {
    "Invite": {
      "title": "Invite",
      "description": "Represents an invitation to join the family tree.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "invitedBy", "createdAt"]
    },
    "OTP": {
      "title": "OTP",
      "description": "Represents a one-time password for login.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "code", "createdAt"]
    },
    "Person": {
      "title": "Person",
      "description": "Represents a person in the family tree.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "birthDate": { "type": "string" },
        "birthPlace": { "type": "string" },
        "deathDate": { "type": "string" },
        "deathPlace": { "type": "string" },
        "bio": { "type": "string" },
        "photo": { "type": "string" },
        "fatherId": { "type": "string" },
        "motherId": { "type": "string" },
        "spouseIds": { "type": "array", "items": { "type": "string" } },
        "childrenIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "firstName", "lastName", "gender", "spouseIds", "childrenIds"]
    },
    "TreeMeta": {
      "title": "TreeMeta",
      "description": "Metadata for the family tree.",
      "type": "object",
      "properties": {
        "rootId": { "type": "string" }
      },
      "required": ["rootId"]
    }
  },
  "firestore": {
    "/invites/{email}": {
      "schema": "Invite",
      "description": "Collection of invites indexed by email."
    },
    "/otps/{email}": {
      "schema": "OTP",
      "description": "Collection of temporary OTPs indexed by email."
    },
    "/users/{userId}/people/{personId}": {
      "schema": "Person",
      "description": "People in a user's family tree."
    },
    "/users/{userId}/meta/tree": {
      "schema": "TreeMeta",
      "description": "Metadata for a user's family tree."
    },
    "/health_check/status": {
      "schema": { "type": "object" },
      "description": "Backend health check document."
    }
  }
}
